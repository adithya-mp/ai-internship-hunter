# ============================================
# ApplyIQ Environment Variables
# ============================================

# Database
DATABASE_URL=postgresql+asyncpg://applyiq:applyiq_secret@db:5432/applyiq
POSTGRES_USER=applyiq
POSTGRES_PASSWORD=applyiq_secret
POSTGRES_DB=applyiq

# Redis
REDIS_URL=redis://redis:6379/0

# JWT Auth
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here

# App
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development

# Scraping
SCRAPE_INTERVAL_HOURS=6
